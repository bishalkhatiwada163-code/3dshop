# For Vercel Deployment

# Database
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/moto-showroom?retryWrites=true&w=majority

# API
API_URL=https://moto-showroom.vercel.app/api
REACT_APP_API_URL=https://moto-showroom.vercel.app/api

# Server
PORT=3000
NODE_ENV=production

# Optional: Monitoring
SENTRY_DSN=

# Optional: Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
