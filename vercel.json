{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "functions": {
    "server.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": [
        "index.html",
        "products.html",
        "admin.html",
        "style.css",
        "app.js",
        "products.js",
        "admin.js",
        "three-viewer.js"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/server.js"
    }
  ],
  "trailingSlash": false
}
